#include <Servo.h>

Servo servo1;
Servo servo2;

int pos1(0);
int pos2(0);

void setup() {

  servo1.attach(9);
  servo2.attach(10);

}

void loop() {
  for(int i = 0; i <= 180; i += 45){
    servo1.write(i);
    servo2.write(i);
    delay(200);
  }
  for(int i = 180; i >=0; i -=45){
    servo1.write(i);
    servo2.write(i);
    delay(200);
  }
}
